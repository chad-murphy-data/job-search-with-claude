# Copy to .env for local runs. In GitHub Actions these become repo secrets.

# --- API keys ---
SERPAPI_KEY=
ANTHROPIC_API_KEY=

# --- Email (Gmail) ---
# EMAIL_PASSWORD must be a Gmail App Password, not your real password.
# https://myaccount.google.com/apppasswords
EMAIL_FROM=your.gmail@gmail.com
EMAIL_TO=your.inbox@example.com
EMAIL_PASSWORD=

# --- Google Sheets (feedback loop) ---
# Paste the entire JSON contents of the service account key as a single-line value.
GOOGLE_SHEETS_CREDENTIALS=
GOOGLE_SHEET_ID=
